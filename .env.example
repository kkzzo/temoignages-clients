# ---- Frame.io API (pour télécharger les vidéos) ----
FRAMEIO_TOKEN=ton_bearer_token_adobe_ims
FRAMEIO_ACCOUNT_ID=xxx-xxx-xxx
FRAMEIO_PROJECT_ID=xxx-xxx-xxx
# ou FRAMEIO_FOLDER_ID=xxx si tu veux télécharger un dossier spécifique

# ---- Bunny Stream (pour uploader et afficher) ----
# Côté serveur uniquement (pour le script d'upload)
BUNNY_API_KEY=ton_api_key_de_la_library_bunny
BUNNY_LIBRARY_ID=12345

# Côté client (pour le player sur la page publique)
NEXT_PUBLIC_BUNNY_LIBRARY_ID=12345
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=vz-xxxxx-xxx.b-cdn.net
